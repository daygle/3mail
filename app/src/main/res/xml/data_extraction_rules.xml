<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for 3mail. Local mail cache is excluded from backups.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="."/>
        <!-- See backup_rules.xml - Keystore master key isn't transferable. -->
        <exclude domain="sharedpref" path="threemail_credentials.xml"/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="."/>
        <!-- Same Keystore edge case as cloud-backup: the Android Keystore master
             key is per-device, so the encrypted credentials file would be
             unverifiable on the target after restore. Other prefs (settings,
             FTS state) still transfer normally. -->
        <exclude domain="sharedpref" path="threemail_credentials.xml"/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="."/>
    </device-transfer>
</data-extraction-rules>
