<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for 3mail. Local mail cache is excluded from backups.
-->
<full-backup-content>
    <include domain="sharedpref" path="."/>
    <!--
        Exclude the encrypted credential prefs specifically: the Android Keystore
        master key used by EncryptedSharedPreferences isn't transferred to a new
        device, so a cloud restore of this file would silently fail to decrypt
        and force the user to re-enter every IMAP password.
    -->
    <exclude domain="sharedpref" path="threemail_credentials.xml"/>
    <!--
        Only the sharedpref domain is included above, so the local mail cache
        (database + files domains) is already excluded from backups by default -
        an explicit <exclude> on a non-included domain is redundant and rejected
        by lint's FullBackupContent check.
    -->
</full-backup-content>
